{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "Default": "__SET_IN_APPSETTINGS_DEVELOPMENT_OR_ENV__"
  },

  "Jwt": {
    "Issuer": "BlinkDemoApi",
    "Audience": "BlinkDemoApiClients",

    "SigningKey": "__SET_IN_APPSETTINGS_DEVELOPMENT_OR_ENV__",

    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 30
  }
}